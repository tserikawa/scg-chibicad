{
    "configurations": [
        {
            "name": "Mac",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/src",
                "/opt/homebrew/include/",
                "${workspaceFolder}/build/_deps/googletest-src/googletest/include"
            ],
            "compilerPath": "/usr/bin/clang++",
            "macFrameworkPath": [
                "/System/Library/Frameworks",
                "/Library/Frameworks"
            ],
            "intelliSenseMode": "macos-clang-arm64",
            "cStandard": "c17",
            "cppStandard": "c++17"
        }
    ],
    "version": 4
}